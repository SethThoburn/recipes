---
import '../styles/global.css';
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href={base} class="site-title">Recipes</a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
